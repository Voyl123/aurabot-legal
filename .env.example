# Copy this file to `.env` and fill in the values.

# Required — your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Optional — set to a server (guild) ID to make slash commands appear instantly
# in that server while you develop. Leave blank to sync globally (can take up
# to an hour to propagate the first time).
DISCORD_GUILD_ID=
